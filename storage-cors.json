[
  {
    "origin": ["*"],
    "method": ["GET", "HEAD", "PUT", "POST", "DELETE", "OPTIONS"],
    "responseHeader": [
      "Content-Type",
      "Authorization",
      "Content-Length",
      "x-goog-resumable",
      "x-goog-upload-url",
      "x-goog-upload-status",
      "x-goog-upload-chunk-granularity",
      "x-goog-upload-control-url",
      "x-goog-meta-firebaseStorageDownloadTokens"
    ],
    "maxAgeSeconds": 3600
  }
]
